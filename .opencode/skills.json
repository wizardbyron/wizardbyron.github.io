      "type": "python",
      "args": {
        "list": {
          "description": "列出备忘录",
          "flag": "--list"
        },
        "import": {
          "description": "导入指定序号的备忘录",
          "flag": "--import"
        }
      }
    },
    {
      "name": "export_to_wechat",
      "description": "将博客文章导出为微信公众号格式",
      "entry": ".opencode/skills/skill_runner.py",
      "type": "python",
      "args": {
        "file": {
          "description": "指定要导出的文件路径"
        },
        "no_open": {
          "description": "不自动打开浏览器",
          "flag": "--no-open"
        }
      }
    }
  ]
